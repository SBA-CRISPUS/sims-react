rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Student documents (birth certificates, medical forms, etc.) hold
    // sensitive PII, so access is scoped to the school's student-managing
    // staff via the caller's schoolCode + role custom claims - NOT to
    // every member of the school. Storage rules only expose read/write,
    // so create/update and delete are distinguished by request.resource
    // (null on delete). Delete is school_admin-only, mirroring the
    // Firestore metadata delete rule. Uploads: PDFs/images up to 10MB.
    // School branding (the logo). Not sensitive - any signed-in user may
    // read (it renders in headers and on printed documents); only the
    // school's administrator uploads/replaces it. Images up to 2MB.
    match /schools/{schoolCode}/branding/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.schoolCode == schoolCode
        && request.auth.token.role == 'school_admin'
        && (request.resource == null
            || (request.resource.size < 2 * 1024 * 1024
                && request.resource.contentType.matches('image/.*')));
    }

    // SBA evidence (paid add-on): photos of learner work and marked
    // written work (PDF) attached to a class score sheet for ECZ
    // moderation. Photos + written work ONLY - no video, by design.
    // Any staff role of the school may read and upload; delete is
    // school_admin-only, mirroring the Firestore metadata rules. The
    // add-on flag itself is checked client-side (Storage rules cannot
    // read Firestore), so a school without the add-on simply has no UI.
    match /schools/{schoolCode}/sbaEvidence/{allPaths=**} {
      allow read: if request.auth != null
        && request.auth.token.schoolCode == schoolCode
        && request.auth.token.role in
             ['school_admin', 'head_teacher', 'deputy_head', 'hod', 'teacher'];
      allow write: if request.auth != null
        && request.auth.token.schoolCode == schoolCode
        && (
          (request.resource != null
            && request.auth.token.role in
                 ['school_admin', 'head_teacher', 'deputy_head', 'hod', 'teacher']
            && request.resource.size < 10 * 1024 * 1024
            && request.resource.contentType.matches('image/.*|application/pdf'))
          ||
          (request.resource == null
            && request.auth.token.role == 'school_admin')
        );
    }

    match /schools/{schoolCode}/students/{studentNumber}/documents/{allPaths=**} {
      allow read: if request.auth != null
        && request.auth.token.schoolCode == schoolCode
        && (request.auth.token.role == 'school_admin'
            || request.auth.token.role == 'head_teacher');

      allow write: if request.auth != null
        && request.auth.token.schoolCode == schoolCode
        && (
          (request.resource != null
            && (request.auth.token.role == 'school_admin'
                || request.auth.token.role == 'head_teacher')
            && request.resource.size < 10 * 1024 * 1024
            && request.resource.contentType.matches('image/.*|application/pdf'))
          ||
          (request.resource == null
            && request.auth.token.role == 'school_admin')
        );
    }
  }
}
