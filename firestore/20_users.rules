    //
    // Identity profiles. Created by the identity Cloud Functions
    // (Admin SDK bypasses rules). Never deleted - accounts are
    // disabled via active: false.
    //

    match /users/{uid} {
      // Self, super admin, or the school's administrator (the Staff
      // Accounts page lists the school's own users - the query's
      // schoolCode filter makes it provable).
      allow read: if signedIn()
        && (request.auth.uid == uid
            || isSuperAdmin()
            || (isSchoolAdmin() && belongsToSchool(resource.data.schoolCode)));

      allow create: if isSuperAdmin();

      // Users may edit their own profile, but the security fields
      // (role, schoolCode, active) only change by super admin or the
      // Admin SDK - otherwise anyone could grant themselves a role
      // and have syncMyClaims mint it into their token. employeeNumber
      // (the teacher link) is likewise CF-only, so a user cannot bind
      // their own account to a teaching identity.
      //
      // A school administrator may flip ONLY `active` on other accounts
      // of their own school (deactivate/reactivate - never their own, so
      // a school always keeps a live admin; onUserProfileWritten then
      // disables the Auth account and revokes tokens). Role changes stay
      // super-admin/CF-only.
      // Self-service is narrow ON PURPOSE: the only thing the app ever
      // lets a user change on their own profile is clearing
      // mustChangePassword after a successful password change (see
      // ChangePasswordForm). hasOnly (not per-field equality checks)
      // means every other field - including role/schoolCode/active/
      // employeeNumber - is structurally impossible to touch here, and
      // the flag can only be turned off, never back on, so a user can't
      // fake "I changed my password" without actually doing it.
      allow update: if isSuperAdmin()
        || (
          signedIn()
          && request.auth.uid == uid
          && request.resource.data.mustChangePassword == false
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['mustChangePassword', 'updatedAt'])
        )
        || (
          isSchoolAdmin()
          && belongsToSchool(resource.data.schoolCode)
          && request.auth.uid != uid
          && resource.data.role != 'super_admin'
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['active', 'updatedAt'])
        );

      allow delete: if false;
    }
