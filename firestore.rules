// GENERATED FILE - DO NOT EDIT DIRECTLY.
// Built from firestore/*.rules - rebuild with: npm run build:rules

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== 00_helpers.rules =====

    //
    // Helper Functions
    //

    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function schoolCode() {
      return request.auth.token.schoolCode;
    }

    function hasRole(r) {
      return signedIn() && role() == r;
    }

    function isSuperAdmin() {
      return hasRole("super_admin");
    }

    function isSchoolAdmin() {
      return hasRole("school_admin");
    }

    // Any school staff member (excludes student/parent).
    function isStaff() {
      return signedIn() && (
        role() == "school_admin"
        || role() == "head_teacher"
        || role() == "deputy_head"
        || role() == "hod"
        || role() == "teacher"
      );
    }

    function belongsToSchool(code) {
      return signedIn() && schoolCode() == code;
    }

    //
    // Capability Functions
    //
    // Role logic lives here, not in the collection rules. Adding a new
    // role (registrar, guidance_counselor, ...) means updating one
    // function, not dozens of match blocks.
    //

    function canManageStudents() {
      return isSchoolAdmin() || hasRole("head_teacher");
    }

    function canManageTeachers() {
      return isSchoolAdmin();
    }

    // Who may create/change teaching assignments (timetabling).
    function canManageAssignments() {
      return isSchoolAdmin() || hasRole("head_teacher");
    }

    // Who may define SBA assessment plans (the task structure a subject is
    // scored against). Subject scoring, moderation and approval get their
    // own finer helpers when marks entry (5B) and the approval workflow
    // (5C) land.
    function canManageAssessments() {
      return isSchoolAdmin() || hasRole("head_teacher") || hasRole("hod");
    }

    // The signed-in user's teacher employee number (from their token), or
    // null for accounts not linked to a teacher record.
    function myEmployeeNumber() {
      return signedIn() ? request.auth.token.get('employeeNumber', null) : null;
    }

    // A teacher "owns" an SBA slot when the slot's denormalized teacherId
    // matches their own employee number.
    function ownsSba(teacherId) {
      return hasRole("teacher")
        && teacherId != null
        && myEmployeeNumber() == teacherId;
    }

    // Who may enter/edit the marks of a slot owned by `teacherId`:
    // assessment managers (admin/head/hod, who may score on anyone's behalf)
    // or the teacher who owns the slot. Replaces the old coarse canScoreSba
    // (which let ANY teacher score ANY class). NOTE: enforcement rides the
    // denormalized teacherId the client stamps from the teaching assignment;
    // a fully assignment-verified check (a rules get() on the slot) is a
    // follow-up once the emulator is available to validate it.
    function canScoreSbaFor(teacherId) {
      return canManageAssessments() || ownsSba(teacherId);
    }

    // Who may moderate a submitted SBA sheet (the HOD step).
    function canModerateSba() {
      return isSchoolAdmin() || hasRole("head_teacher") || hasRole("hod");
    }

    // Who may approve/sign off an SBA sheet (the Head Teacher step). This
    // freezes the marks - the approval Cloud Function computes the final
    // raw scores.
    function canApproveSba() {
      return isSchoolAdmin() || hasRole("head_teacher") || hasRole("deputy_head");
    }

    function canManageAcademicStructure() {
      return isSchoolAdmin();
    }

    // Who may initiate an outgoing transfer / decide an incoming one
    // (Phase 8). Head office actions - never a plain teacher.
    function canInitiateTransfer() {
      return isSchoolAdmin() || hasRole("head_teacher");
    }
    function canDecideTransfer() {
      return isSchoolAdmin() || hasRole("head_teacher");
    }

    function canViewReports() {
      return isSchoolAdmin()
        || hasRole("head_teacher")
        || hasRole("teacher");
    }

    // ===== 10_system.rules =====

    //
    // System master data: grading systems, academic structures,
    // countries, subscription plans, counters. Super admin only.
    //
    // Read is super-admin-only: the counter (nextSchoolNumber) would
    // otherwise let any signed-in user enumerate every school code.
    // The only client reader is the super-admin provisioning
    // transaction. If shared reference data (grading systems,
    // countries) later needs tenant-wide read, move it to its own
    // collection rather than widening this rule.
    //

    match /system/{document=**} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // Platform learner registry (Phase 8). The permanent SIMS learner id
    // and a pointer to the learner's current school. Written only by the
    // Cloud Functions (Admin SDK); a school reads a learner's id off its
    // own student document, so client read here is super-admin only.
    match /learners/{learnerId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // ===== 20_users.rules =====

    //
    // Identity profiles. Created by the identity Cloud Functions
    // (Admin SDK bypasses rules). Never deleted - accounts are
    // disabled via active: false.
    //

    match /users/{uid} {
      allow read: if signedIn()
        && (request.auth.uid == uid || isSuperAdmin());

      allow create: if isSuperAdmin();

      // Users may edit their own profile, but the security fields
      // (role, schoolCode, active) only change by super admin or the
      // Admin SDK - otherwise anyone could grant themselves a role
      // and have syncMyClaims mint it into their token. employeeNumber
      // (the teacher link) is likewise CF-only, so a user cannot bind
      // their own account to a teaching identity.
      allow update: if isSuperAdmin()
        || (
          signedIn()
          && request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.schoolCode == resource.data.schoolCode
          && request.resource.data.active == resource.data.active
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['employeeNumber'])
        );

      allow delete: if false;
    }

    // ===== 30_schools.rules =====

    //
    // School tenants and their provisioned structure.
    //
    // Writes allow isSuperAdmin() because school provisioning
    // currently runs client-side under the super admin account.
    // When provisioning moves into a Cloud Function, tighten these
    // to school-admin-only.
    //

    match /schools/{schoolId} {
      allow read: if isSuperAdmin() || belongsToSchool(schoolId);
      allow create: if isSuperAdmin();

      // A school_admin may edit their school's descriptive fields
      // (name, location, contact) but NOT the fields that represent
      // entitlement or lifecycle - subscription tier, status,
      // provisioning state, and identity codes stay super-admin-only,
      // or a school_admin could self-grant Enterprise / un-suspend.
      allow update: if isSuperAdmin()
        || (
          belongsToSchool(schoolId)
          && isSchoolAdmin()
          && request.resource.data.schoolCode == resource.data.schoolCode
          && request.resource.data.emisCode == resource.data.emisCode
          && request.resource.data.subscription == resource.data.subscription
          && request.resource.data.status == resource.data.status
          && request.resource.data.provisioning == resource.data.provisioning
        );

      allow delete: if false;
    }

    match /schools/{schoolId}/settings/{settingId} {
      allow read: if isSuperAdmin() || belongsToSchool(schoolId);
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin()
        || (belongsToSchool(schoolId) && isSchoolAdmin());
      allow delete: if false;
    }

    // School-local sequential counters (students, guardians,
    // admissions, later teachers/receipts). School-scoped, so a
    // school_admin/head_teacher reads and increments them inside the
    // admission transaction - global IDs stay in /system. Access
    // mirrors canManageStudents for this sprint's counters; tighten
    // per-counter when teacher/receipt counters arrive.
    match /schools/{schoolId}/counters/{counterId} {
      allow read: if isSuperAdmin()
        || (belongsToSchool(schoolId) && canManageStudents());
      // The teacher counter is only written when registering a teacher
      // (school_admin), so match that authority rather than the broader
      // student-admitting one.
      allow create, update: if belongsToSchool(schoolId)
        && (counterId == 'teachers' ? canManageTeachers() : canManageStudents());
      allow delete: if false;
    }

    match /schools/{schoolId}/departments/{departmentId} {
      allow read: if isSuperAdmin() || belongsToSchool(schoolId);
      allow write: if isSuperAdmin()
        || (belongsToSchool(schoolId) && canManageAcademicStructure());
    }

    // Subjects a school teaches. Managed by academic-structure staff.
    // The subjectCode field is pinned to the doc id (create) and immutable
    // (update), so the doc-id == subjectCode invariant the services rely
    // on can't be broken by a raw client write.
    match /schools/{schoolId}/subjects/{subjectId} {
      allow read: if isSuperAdmin() || belongsToSchool(schoolId);
      allow create: if belongsToSchool(schoolId)
        && canManageAcademicStructure()
        && request.resource.data.subjectCode == subjectId;
      allow update: if belongsToSchool(schoolId)
        && canManageAcademicStructure()
        && request.resource.data.subjectCode == resource.data.subjectCode;
      allow delete: if false;
    }

    match /schools/{schoolId}/academicLevels/{levelId} {
      allow read: if isSuperAdmin() || belongsToSchool(schoolId);
      allow write: if isSuperAdmin()
        || (belongsToSchool(schoolId) && canManageAcademicStructure());
    }

    // Class streams, flat under the school and keyed by
    // "{levelCode}-{streamCode}" (e.g. F1-A). Structural fields
    // (name/capacity/active/classTeacherId) are managed by academic
    // staff. occupiedCount and the identity fields (streamId/streamCode/
    // academicLevelCode) are locked against client writes by the field
    // guards below; occupiedCount is owned solely by the
    // onEnrollmentWritten Cloud Function (Admin SDK bypasses rules).
    match /schools/{schoolId}/streams/{streamId} {
      allow read: if isSuperAdmin() || belongsToSchool(schoolId);
      allow create: if belongsToSchool(schoolId)
        && canManageAcademicStructure()
        && request.resource.data.streamId == streamId
        && request.resource.data.occupiedCount == 0;
      allow update: if belongsToSchool(schoolId)
        && canManageAcademicStructure()
        && request.resource.data.occupiedCount == resource.data.occupiedCount
        && request.resource.data.streamId == resource.data.streamId
        && request.resource.data.streamCode == resource.data.streamCode
        && request.resource.data.academicLevelCode == resource.data.academicLevelCode;
      // Deletable so a mistyped stream CODE can be fixed (rename = create
      // new id + move enrollments + delete old, one atomic batch in
      // StreamService.renameStream). Streams are structure, not history -
      // nothing academic is stored on the stream doc itself. The service
      // refuses to rename once teaching assignments / SBA sheets reference
      // the stream (their deterministic ids embed it).
      allow delete: if belongsToSchool(schoolId) && canManageAcademicStructure();
    }

    match /schools/{schoolId}/academicYears/{yearId} {
      allow read: if isSuperAdmin() || belongsToSchool(schoolId);
      allow write: if isSuperAdmin()
        || (belongsToSchool(schoolId) && canManageAcademicStructure());
    }

    match /schools/{schoolId}/academicYears/{yearId}/terms/{termId} {
      allow read: if isSuperAdmin() || belongsToSchool(schoolId);
      allow write: if isSuperAdmin()
        || (belongsToSchool(schoolId) && canManageAcademicStructure());
    }

    // ===== 40_students.rules =====

    //
    // Students and their guardians. Deletion is disabled - students
    // are deactivated, preserving academic history.
    //
    // Note: school-wide read is Phase 1. When the Students module
    // lands, narrow student/parent roles to their own records.
    //

    match /schools/{schoolId}/students/{studentId} {
      allow read: if isSuperAdmin() || belongsToSchool(schoolId);
      allow create: if belongsToSchool(schoolId) && canManageStudents();
      allow update: if belongsToSchool(schoolId) && canManageStudents();
      allow delete: if false;
    }

    match /schools/{schoolId}/guardians/{guardianId} {
      allow read: if isSuperAdmin() || belongsToSchool(schoolId);
      allow create: if belongsToSchool(schoolId) && canManageStudents();
      allow update: if belongsToSchool(schoolId) && canManageStudents();
      allow delete: if false;
    }

    // Enrollment is historical academic data - append-only, never
    // deleted. Top-level under the school (not nested under a student)
    // so "all learners in Form 2 / Stream B / this year" is one query.
    match /schools/{schoolId}/enrollments/{enrollmentId} {
      allow read: if isSuperAdmin() || belongsToSchool(schoolId);
      allow create: if belongsToSchool(schoolId) && canManageStudents();
      allow update: if belongsToSchool(schoolId) && canManageStudents();
      allow delete: if false;
    }

    // Student document metadata. The files live in Firebase Storage
    // (see storage.rules); this is only the metadata. Documents hold
    // sensitive PII, so read is scoped to student-managing staff (not
    // every school member, and not plain teachers) - matching the
    // storage rules. Deletable by a school_admin so mistaken uploads
    // can be removed.
    match /schools/{schoolId}/students/{studentId}/documents/{documentId} {
      allow read: if belongsToSchool(schoolId) && canManageStudents();
      allow create, update: if belongsToSchool(schoolId) && canManageStudents();
      allow delete: if belongsToSchool(schoolId) && isSchoolAdmin();
    }

    // ===== 50_teachers.rules =====

    //
    // Teachers. Deletion is disabled - staff are deactivated.
    // Records hold PII (phone, email, TSC number), so read is scoped to
    // staff rather than every school member (students/parents cannot
    // read staff contact data once those accounts exist).
    //

    // linkedUserUid is the link to the teacher's Auth account. It is set
    // ONLY by the createTeacherAccount Cloud Function (Admin SDK) - a client
    // must never write it, or a teacher could point their HR record at
    // someone else's login. Everything else is managed by teacher-admins.
    match /schools/{schoolId}/teachers/{teacherId} {
      allow read: if isSuperAdmin() || (belongsToSchool(schoolId) && isStaff());
      allow create: if belongsToSchool(schoolId) && canManageTeachers()
        && !request.resource.data.keys().hasAny(['linkedUserUid']);
      allow update: if belongsToSchool(schoolId) && canManageTeachers()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['linkedUserUid']);
      allow delete: if false;
    }

    // Teaching assignments (who teaches what, to which class, this term).
    // Deactivated, never deleted. The doc id, the id field, and the four
    // slot-component fields must all be mutually consistent, so the
    // one-teacher-per-(subject,stream,term) slot invariant actually holds
    // and the SBA engine can trust the slot key. Read is staff-only, like
    // the teachers collection.
    match /schools/{schoolId}/teachingAssignments/{assignmentId} {
      allow read: if isSuperAdmin() || (belongsToSchool(schoolId) && isStaff());

      allow create: if belongsToSchool(schoolId)
        && canManageAssignments()
        && request.resource.data.id == assignmentId
        && request.resource.data.id ==
             request.resource.data.academicYearId + '_'
             + request.resource.data.termId + '_'
             + request.resource.data.streamId + '_'
             + request.resource.data.subjectId
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.active == true
        && request.resource.data.periodsPerWeek is int
        && request.resource.data.periodsPerWeek > 0;

      allow update: if belongsToSchool(schoolId)
        && canManageAssignments()
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.academicYearId == resource.data.academicYearId
        && request.resource.data.termId == resource.data.termId
        && request.resource.data.streamId == resource.data.streamId
        && request.resource.data.subjectId == resource.data.subjectId
        && request.resource.data.periodsPerWeek is int
        && request.resource.data.periodsPerWeek > 0;

      allow delete: if false;
    }

    // ===== 60_assessments.rules =====

    //
    // SBA assessments. Sprint 5A: assessment plans - the task structure a
    // subject is scored against, per form-year. Marks entry and the
    // submit -> moderate -> approve -> lock workflow land in 5B/5C; until
    // then the default deny covers those paths.
    //
    // Plans carry no PII, but the whole assessments module is staff-scoped,
    // so read is staff-only (excludes student/parent). The doc id encodes
    // the slot {academicYearId}_{academicLevelCode}_{subjectId} and is
    // reconstructed from the stored fields (like teachingAssignments), so
    // one plan == one (subject, form-year) and a raw client write can't
    // desync the id from its fields. SBA runs in Form 2 and Form 3 only.
    //
    match /schools/{schoolId}/sbaPlans/{planId} {
      allow read: if isSuperAdmin() || (belongsToSchool(schoolId) && isStaff());

      allow create: if belongsToSchool(schoolId)
        && canManageAssessments()
        && request.resource.data.planId == planId
        && planId ==
             request.resource.data.academicYearId + '_'
             + request.resource.data.academicLevelCode + '_'
             + request.resource.data.subjectId
        && (request.resource.data.academicLevelCode == 'F2'
            || request.resource.data.academicLevelCode == 'F3')
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.status == 'draft';

      // Identity/slot fields and the plan's origin are frozen; only the
      // task list and the draft/published status may change - and the task
      // list is frozen once published (unpublish to draft to edit it),
      // matching SbaPlanService and pre-empting task edits under scored
      // marks in 5B/5C. Publish/unpublish is a status-only update, so the
      // task list is unchanged and the equality guard passes.
      allow update: if belongsToSchool(schoolId)
        && canManageAssessments()
        && request.resource.data.planId == resource.data.planId
        && request.resource.data.academicYearId == resource.data.academicYearId
        && request.resource.data.academicLevelCode == resource.data.academicLevelCode
        && request.resource.data.subjectId == resource.data.subjectId
        && request.resource.data.createdByUid == resource.data.createdByUid
        && (request.resource.data.status == 'draft'
            || request.resource.data.status == 'published')
        && (resource.data.status != 'published'
            || request.resource.data.tasks == resource.data.tasks);

      allow delete: if false;
    }

    //
    // SBA class submissions (Sprint 5B): one class's subject sheet =
    // (academic year, stream, subject) - the workflow unit a subject
    // teacher submits and a Head Teacher approves (5C). The id encodes the
    // slot {academicYearId}_{streamId}_{subjectId} (the teaching slot minus
    // the term, because SBA is scored per form-year). Status carries the
    // workflow; identity/slot fields are frozen after creation.
    // lastActionByUid is stamped to the caller so the audit trigger (5C)
    // can attribute each transition. Moderation/approval land in 5C; 5B
    // exercises draft -> submitted (scorer) and submitted -> draft (a
    // manager reopening for correction).
    //
    match /schools/{schoolId}/sbaSubmissions/{submissionId} {
      allow read: if isSuperAdmin() || (belongsToSchool(schoolId) && isStaff());

      allow create: if belongsToSchool(schoolId)
        && canScoreSbaFor(request.resource.data.get('teacherId', null))
        && request.resource.data.submissionId == submissionId
        && submissionId ==
             request.resource.data.academicYearId + '_'
             + request.resource.data.streamId + '_'
             + request.resource.data.subjectId
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.lastActionByUid == request.auth.uid
        && request.resource.data.status == 'draft';

      allow update: if belongsToSchool(schoolId)
        && request.resource.data.submissionId == resource.data.submissionId
        && request.resource.data.planId == resource.data.planId
        && request.resource.data.academicYearId == resource.data.academicYearId
        && request.resource.data.academicLevelCode == resource.data.academicLevelCode
        && request.resource.data.streamId == resource.data.streamId
        && request.resource.data.subjectId == resource.data.subjectId
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.lastActionByUid == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['teacherId'])
        && (
             // subject teacher (owner) submits an open sheet
             (canScoreSbaFor(resource.data.get('teacherId', null))
               && (resource.data.status == 'draft'
                   || resource.data.status == 'returned')
               && request.resource.data.status == 'submitted')
             ||
             // manager reopens a submitted sheet straight to draft
             (canManageAssessments()
               && resource.data.status == 'submitted'
               && request.resource.data.status == 'draft')
             ||
             // HOD moderates a submitted sheet
             (canModerateSba()
               && resource.data.status == 'submitted'
               && request.resource.data.status == 'moderated')
             ||
             // Head Teacher approves (moderation may be skipped)
             (canApproveSba()
               && (resource.data.status == 'submitted'
                   || resource.data.status == 'moderated')
               && request.resource.data.status == 'approved')
             ||
             // HOD/Head returns a sheet for correction
             ((canModerateSba() || canApproveSba())
               && (resource.data.status == 'submitted'
                   || resource.data.status == 'moderated')
               && request.resource.data.status == 'returned')
           );

      allow delete: if false;

      // Append-only workflow history, written only by the audit Cloud
      // Function (Admin SDK). Staff-readable so moderators/heads can see
      // who did what and why; never editable or deletable by anyone.
      match /events/{eventId} {
        allow read: if isSuperAdmin() || (belongsToSchool(schoolId) && isStaff());
        allow create, update, delete: if false;
      }
    }

    //
    // SBA marks (Sprint 5B): one learner's task scores for a class, flat
    // under schools/{code}/sbaMarks. The id encodes the slot
    // {academicYearId}_{streamId}_{subjectId}_{studentId}. Scores are
    // editable only while the sheet is open (draft/returned); once
    // submitted they are frozen (a manager may reopen the sheet but not
    // edit scores). The frozen totals obtainedTotal/rawScore are written
    // solely by the approval Cloud Function (5C, Admin SDK) - clients can
    // never set or change them.
    //
    match /schools/{schoolId}/sbaMarks/{markId} {
      allow read: if isSuperAdmin() || (belongsToSchool(schoolId) && isStaff());

      allow create: if belongsToSchool(schoolId)
        && canScoreSbaFor(request.resource.data.get('teacherId', null))
        && request.resource.data.id == markId
        && markId ==
             request.resource.data.academicYearId + '_'
             + request.resource.data.streamId + '_'
             + request.resource.data.subjectId + '_'
             + request.resource.data.studentId
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.lastActionByUid == request.auth.uid
        && request.resource.data.status == 'draft'
        && request.resource.data.taskScores is map
        && !request.resource.data.keys().hasAny(['obtainedTotal', 'rawScore']);

      allow update: if belongsToSchool(schoolId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.academicYearId == resource.data.academicYearId
        && request.resource.data.academicLevelCode == resource.data.academicLevelCode
        && request.resource.data.streamId == resource.data.streamId
        && request.resource.data.subjectId == resource.data.subjectId
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.planId == resource.data.planId
        && request.resource.data.submissionId == resource.data.submissionId
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.lastActionByUid == request.auth.uid
        && request.resource.data.taskScores is map
        && !request.resource.data.diff(resource.data)
              .affectedKeys().hasAny(['obtainedTotal', 'rawScore', 'teacherId'])
        && (
             // owning teacher edits/submits while the sheet is open
             (canScoreSbaFor(resource.data.get('teacherId', null))
               && (resource.data.status == 'draft'
                   || resource.data.status == 'returned')
               && (request.resource.data.status == 'draft'
                   || request.resource.data.status == 'returned'
                   || request.resource.data.status == 'submitted'))
             ||
             // every non-scorer transition below only moves status - the
             // scores and the not-taking flag are frozen.
             (
               (request.resource.data.taskScores == resource.data.taskScores
                && request.resource.data.notTaking == resource.data.notTaking)
               && (
                    // manager reopens straight to draft
                    (canManageAssessments()
                      && resource.data.status == 'submitted'
                      && request.resource.data.status == 'draft')
                    ||
                    // HOD moderates
                    (canModerateSba()
                      && resource.data.status == 'submitted'
                      && request.resource.data.status == 'moderated')
                    ||
                    // Head Teacher approves (freeze follows via the CF)
                    (canApproveSba()
                      && (resource.data.status == 'submitted'
                          || resource.data.status == 'moderated')
                      && request.resource.data.status == 'approved')
                    ||
                    // HOD/Head returns for correction
                    ((canModerateSba() || canApproveSba())
                      && (resource.data.status == 'submitted'
                          || resource.data.status == 'moderated')
                      && request.resource.data.status == 'returned')
                  )
             )
           );

      allow delete: if false;
    }

    // ===== 70_reports.rules =====

    //
    // Reports. Rules land with the reports module (canViewReports is
    // already defined in 00_helpers). Until then the default deny
    // covers these paths.
    //

    // ===== 80_audit.rules =====

    //
    // Audit logs are written exclusively by Cloud Functions via the
    // Admin SDK. No client ever writes, updates, or deletes them.
    //

    match /schools/{schoolId}/auditLogs/{logId} {
      allow read: if isSuperAdmin()
        || (belongsToSchool(schoolId) && isSchoolAdmin());
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ===== 90_transfers.rules =====

    //
    // Cross-school student transfers (Phase 8).
    //
    // THE ONLY MULTI-TENANT SHARED SURFACE in SIMS. A transfer request is
    // visible to its two parties only (sender or receiver), never as a
    // directory of another school's learners. The sending head/admin
    // creates it (carrying a self-contained snapshot); the receiving
    // head/admin decides (accept / reject / request info). The 'completed'
    // import - creating the receiving enrollment, closing the sending one,
    // and every cross-school write - is done solely by the
    // onTransferAccepted Cloud Function (Sprint 8.3, Admin SDK), never a
    // client. Snapshot + party fields are frozen once created.
    //
    match /transferRequests/{requestId} {
      allow read: if isSuperAdmin()
        || belongsToSchool(resource.data.fromSchoolCode)
        || belongsToSchool(resource.data.toSchoolCode);

      allow create: if belongsToSchool(request.resource.data.fromSchoolCode)
        && canInitiateTransfer()
        && request.resource.data.requestId == requestId
        && request.resource.data.status == 'requested'
        && request.resource.data.requestedByUid == request.auth.uid
        && request.resource.data.toSchoolCode is string
        && request.resource.data.toSchoolCode != request.resource.data.fromSchoolCode
        // CF-owned fields can't be forged at creation (the transfer number
        // is minted server-side from the global counter).
        && !request.resource.data.keys().hasAny(
             ['transferNumber', 'importedStudentNumber', 'completedAt']);

      // Two client transitions exist; everything else (completed, the
      // transferNumber stamp) is the Cloud Function's (Admin SDK).
      //
      // 1. The RECEIVING school's head/admin decides - from 'requested' or
      //    'info_requested' (asking for info must not dead-end the request;
      //    once satisfied, the receiver accepts/rejects). Only status +
      //    decision metadata may change - the envelope and the parties are
      //    immutable.
      // 2. The SENDING school's head/admin cancels a not-yet-decided
      //    request (schools change their minds; also the MVP way to refresh
      //    a stale envelope: cancel + re-send).
      allow update: if (
          belongsToSchool(resource.data.toSchoolCode)
          && canDecideTransfer()
          && (resource.data.status == 'requested'
              || resource.data.status == 'info_requested')
          && (request.resource.data.status == 'accepted'
              || request.resource.data.status == 'rejected'
              || request.resource.data.status == 'info_requested')
          && request.resource.data.decidedByUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'decidedByUid', 'decisionNote', 'decidedAt', 'updatedAt'])
        ) || (
          belongsToSchool(resource.data.fromSchoolCode)
          && canInitiateTransfer()
          && (resource.data.status == 'requested'
              || resource.data.status == 'info_requested')
          && request.resource.data.status == 'cancelled'
          && request.resource.data.cancelledByUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'cancelledByUid', 'updatedAt'])
        );

      allow delete: if false;
    }

  }
}
